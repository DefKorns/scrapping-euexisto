	</div><script>

	if(!window.SAPO) window.SAPO = {};
	if(!window.SAPO.newsletter) window.SAPO.newsletter = {};

	window.SAPO.newsletter.success = () => {

		const newsletterForm = document.getElementById('mc_embed_signup'),
			modal = document.querySelector('[data-id="modal-newsletter"]'),
			hide = !modal ? null : modal.querySelectorAll('.text-base, #mc-embedded-subscribe');

		if (!newsletterForm) return;

		const newsletterMessage = document.createElement('div');
		newsletterMessage.className = 'custom-success-message fade-in';
		newsletterMessage.innerHTML = "<div class='thank-you-message text-center'><h2 class='text-center mb-2'>É bom ver-te por aqui!</h2><p class='subTitle'>Vai ao teu e-mail e clica no link que te enviámos para confirmar a subscrição. Se não o encontrares, espreita na pasta de spam.</p></div>";

		newsletterForm.parentNode.insertBefore(newsletterMessage, newsletterForm);

		hide && hide.length && Array.from(hide).concat(newsletterForm).forEach((el) => {
			if(!el) return;
			el.style.display = 'none';
		});
	};
</script>

<form data-widget="modal" data-id="modal-newsletter" data-oversize class="modal-newsletter validate" onsubmit="window.SAPO.newsletter.success()"
	
	
	data-hash 
		action="https://sapo.us14.list-manage.com/subscribe/post?u=189fa40f12144da7806631fb8&amp;id=6bddd2bca0&amp;f_id=0040b9e5f0"
	
	method="post" id="mc-embedded-subscribe-form" name="mc-embedded-subscribe-form" target="_blank">
	<div class="modal-newsletter-content">
		<div id="mc_embed_signup" class="mc-cols">
			<div class="col-left">
				<h3 class="text-left">Newsletter do SAPO</h3>
					<p class="text-xl">Recebe todos os dias, no teu e-mail, as notícias que valem a pena ver.</p></div>

			<div class="col-right" >

				<div id="mc_embed_signup_scroll" class="flex flex-wrap justify-between">
					
					<div class="mc-field-group mc-full">
						<label for="mce-EMAIL">Email <span class="asterisk">*</span></label>
						<input type="email" name="EMAIL" class="required email" id="mce-EMAIL" required placeholder="O teu email" data-error="Endereço de email inválido">
					</div>
					<div class="mc-field-group mc-half">
						<label for="mce-AGE">Idade</label>
						<input type="number" name="AGE" class="text" id="mce-AGE" placeholder="A tua idade" min="13" data-error="Tem de ter pelo menos 13 anos">
					</div>
					<div class="mc-field-group mc-half select-wrapper">
						<label for="mce-GENDER">Género</label>

							<select name="GENDER" class="dropdown" id="mce-GENDER">
								<option value="" selected disabled>Seleciona</option>
								<option value="Masculino">Masculino</option>
								<option value="Feminino">Feminino</option>
								<option value="Prefiro não dizer">Prefiro não dizer</option>
							</select>
					</div>
					<div class="mc-field-group checks mc-full">
						<label><input type="checkbox" name="CONSENT_NEWSLETTER" value="yes" required data-error> <span
								class="asterisk">*</span> Autorizo expressamente o tratamento do meu endereço de correio
							eletrónico para efeito de envio de newsletters do SAPO.</label>
						<label><input type="checkbox" name="CONSENT_PRIVACY" value="yes" required data-error> <span
								class="asterisk">*</span> Li e aceito a <a
								href="https://ajuda.sapo.pt/politica-de-privacidade-7675" target="_blank"> Política de
								Privacidade </a></label>
						<label><input type="checkbox" name="CONSENT_MARKETING" value="yes" > Autorizo o tratamento dos meus dados pessoais pela MEO para fins de
							marketing, designadamente para a comercialização de produtos e serviços.</label>
					</div>
					
					<div aria-hidden="true" style="position: absolute; left: -5000px;">
						<input type="text" name="b_189fa40f12144da7806631fb8_0450e5c726" tabindex="-1" value="">
					</div>
					<div class="indicates-required mc-full"><span class="asterisk">*</span> Campo obrigatório</div>
					<input class="button mt-2" type="submit" name="subscribe" id="mc-embedded-subscribe" value="Subscrever">
					
				</div>

			</div>
		</div>
	</div>
	<div class="w-full footer-modal-sapo"> </div>

</form></footer>
